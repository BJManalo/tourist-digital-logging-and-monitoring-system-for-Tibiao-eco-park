{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/css/(.*)",
            "destination": "/css/$1"
        },
        {
            "source": "/js/(.*)",
            "destination": "/js/$1"
        },
        {
            "source": "/images/(.*)",
            "destination": "/images/$1"
        },
        {
            "source": "/login.html",
            "destination": "/assets/login.html"
        },
        {
            "source": "/staff.html",
            "destination": "/assets/staff.html"
        },
        {
            "source": "/admin.html",
            "destination": "/assets/admin.html"
        },
        {
            "source": "/(.*)",
            "destination": "/assets/index.html"
        }
    ]
}