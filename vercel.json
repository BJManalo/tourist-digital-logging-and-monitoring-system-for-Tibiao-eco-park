{
    "version": 2,
    "builds": [
        {
            "src": "server.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "server.js"
        },
        {
            "src": "/css/(.*)",
            "dest": "/public/css/$1"
        },
        {
            "src": "/js/(.*)",
            "dest": "/public/js/$1"
        },
        {
            "src": "/images/(.*)",
            "dest": "/public/images/$1"
        },
        {
            "src": "/login.html",
            "dest": "/public/assets/login.html"
        },
        {
            "src": "/staff.html",
            "dest": "/public/assets/staff.html"
        },
        {
            "src": "/admin.html",
            "dest": "/public/assets/admin.html"
        },
        {
            "src": "/(.*)",
            "dest": "/public/assets/index.html"
        }
    ]
}